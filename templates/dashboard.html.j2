<!-- PLOTLY CHART RENDERING -->
<!-- ══════════════════════════════════════════════════════════════ -->
<script>
const A = {{ analysis }};
const plotConfig = { responsive: true, displayModeBar: false };

function renderChart(id, chartKey) {
  const chart = A.charts[chartKey];
  if (!chart) return;
  Plotly.newPlot(id, chart.data, chart.layout, plotConfig);
}

// Render all charts
renderChart('chart-daily-revenue', 'daily_revenue');
renderChart('chart-dow-revenue', 'dow_revenue');
renderChart('chart-aov-trend', 'aov_trend');
renderChart('chart-wow-growth', 'wow_growth');
renderChart('chart-hourly-heatmap', 'hourly_heatmap');
renderChart('chart-morning-rush', 'morning_rush');
renderChart('chart-order-size-dist', 'order_size_dist');
renderChart('chart-top-items-revenue', 'top_items_revenue');
renderChart('chart-top-items-qty', 'top_items_qty');
renderChart('chart-category-mix', 'category_mix');
renderChart('chart-category-trend', 'category_trend');
renderChart('chart-weather-correlation', 'weather_correlation');
renderChart('chart-tips', 'tips');
renderChart('chart-staffing-model', 'staffing_model');
renderChart('chart-staff-volume-correlation', 'staff_volume_correlation');
renderChart('chart-staff-shifts-timeline', 'staff_shifts_timeline');

// Hide chart wrappers if no data
if (!A.charts['staff_volume_correlation']) {
  const el = document.getElementById('chart-staff-volume-wrapper');
  if (el) el.style.display = 'none';
}
if (!A.charts['staff_shifts_timeline']) {
  const el = document.getElementById('chart-staff-timeline-wrapper');
  if (el) el.style.display = 'none';
}

// Handle window resize for all charts
window.addEventListener('resize', () => {
  document.querySelectorAll('.chart-container').forEach(el => {
    if (el.data) Plotly.Plots.resize(el);
  });
});

// Smooth scroll for nav links
document.querySelectorAll('.nav a').forEach(link => {
  link.addEventListener('click', (e) => {
    const href = link.getAttribute('href');
    if (href.startsWith('#')) {
      e.preventDefault();
      document.querySelector(href)?.scrollIntoView({ behavior: 'smooth' });
    }
  });
});
</script>

</body>
</html>
